doctype html 
html 
    head 
        title #{pageTitle}
        link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css")
        link(rel="stylesheet", href="/admin/css/style.css")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css")

    body 
        if(role.permissions.length > 0)
            //- Header nằm trên cùng
            include ../partials/header.pug
            
            //- Bọc Sidebar và Main trong một khối Flex
            .page-wrapper
                .sider 
                    include ../partials/sider.pug
                
                .main 
                    block main 
        else 
            .container
                .alert.alert-danger.mt-5(role="alert")
                    | Tài khoản của bạn không có quyền truy cập vào trang quản trị.
        
        script(src="/admin/js/script.js")
        //- Các script khác của bạn...
        script(src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js") 
        script(src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js")