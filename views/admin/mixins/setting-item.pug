mixin setting-item(icon, title, desc, link)
    .col-md-3.mb-4
      a(href=link style="text-decoration: none; color: inherit; display: flex; align-items: flex-start;")
        i(class=icon style="font-size: 24px; margin-right: 15px; color: #5c5c5c;")
        div
          h6.mb-1= title
          p.text-muted.small.mb-0= desc