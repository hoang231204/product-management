extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-success(5000)
    .container.my-5
        .card.p-4.shadow-sm
            h1.mb-4.font-weight-bold Chỉnh sửa hồ sơ

            form(
                action=`${prefixAdmin}/my-profile/edit?_method=PATCH`
                method="POST"
                enctype="multipart/form-data"
                form-upload
            )
                //- Họ tên
                div(class="form-group mb-3")
                    label(for="fullname" class="form-label font-weight-bold") Họ tên *
                    input(
                        type="text"
                        class="form-control"
                        id="fullname"
                        name="fullname"
                        value=user.fullname
                        required
                    )

                //- Email
                div(class="form-group mb-3")
                    label(for="email" class="form-label font-weight-bold") Email *
                    input(
                        type="email"
                        class="form-control"
                        id="email"
                        name="email"
                        value=user.email
                        required
                    )

                //- Mật khẩu
                div(class="form-group mb-3")
                    label(for="password" class="form-label font-weight-bold") Mật khẩu
                    input(
                        type="password"
                        class="form-control"
                        id="password"
                        name="password"
                        placeholder="Nhập mật khẩu mới nếu muốn thay đổi"
                    )
                    small.text-muted * Để trống nếu giữ nguyên mật khẩu cũ
 
                //- Số điện thoại
                div(class="form-group mb-3")
                    label(for="phone" class="form-label font-weight-bold") Số điện thoại
                    if user.phone
                        input(
                            type="text"
                            class="form-control"
                            id="phone"
                            name="phone"
                            value=user.phone
                        )
                    else
                        input(
                            type="text"
                            class="form-control"
                            id="phone"
                            name="phone"
                            placeholder="Chưa có số điện thoại"
                        )

                //- Avatar (Giữ nguyên cấu trúc logic để không mất sự kiện)
                div(class="form-group mb-4" upload-image)
                    label(for="avatar" class="form-label font-weight-bold") Avatar
                    input(
                        type="file"
                        class="form-control-file d-block mb-2"
                        id="avatar"
                        name="avatar"
                        accept="image/*"
                        upload-image-input
                    )
                    div(class="box-image d-inline-block border p-2 rounded")
                        img(
                            src=user.avatar
                            upload-image-preview
                            class="image-preview d-block mb-2"
                            style="max-width: 150px;"
                        )
                        button(
                            type="button"
                            class="btn-remove-image btn btn-danger btn-sm"
                            aria-label="Remove image"
                        ) ×
                //- Nút submit
                div(class="form-group")
                    button(
                        type="submit"
                        class="btn btn-primary px-4"
                    ) Cập nhật
                    a(
                        href=`${prefixAdmin}/my-profile`
                        class="btn btn-secondary ml-2 px-4"
                    ) Hủy bỏ