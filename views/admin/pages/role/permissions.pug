extends ../../layouts/default.pug
block main
    if(role.permissions.includes("permission"))
        h1 PHÂN QUYỀN
        if(records)
            div 
                input(type="text" value=records class="form-control form-control-sm mt-1 text-center d-none" readonly input-records)
            div(class="text-right")
                button(
                    type="submit"
                    class="btn btn-primary mb-3"
                    button-submit
