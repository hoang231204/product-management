extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-error(5000)
    +alert-success(5000)

    .container.my-5
        .card.form-card
            h2(class="mb-4 text-center") Chỉnh sửa vai trò
            form(
                action=`${prefixAdmin}/roles/edit/${role._id}?_method=PATCH` 
                method="POST" 
                form-upload
            )
                .row
                    .col-12
                        .form-group
                            label Tiêu đề *
                            input(
                                type="text"
                                class="form-control"
                                name="title"
                                value=role.title
                                required 
                            )
                .row
                    .col-12
                        .form-group
                            label Mô tả ngắn
                            textarea(
                                class="form-control textarea-mce"
                                name="description"
                                rows="5"
                            )!= role.description
                
                .text-right.mt-4
                    button(type="submit" class="btn btn-primary px-5 mr-2") Cập nhật
                    a(href=`${prefixAdmin}/roles` class="btn btn-secondary") Quay lại