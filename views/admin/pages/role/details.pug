extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-success(5000)
    
    .container.my-5
        h1.mb-4.font-weight-bold CHI TIẾT VAI TRÒ
        
        if role
            .card.shadow-sm
                .card-body
                    //- Thông tin chính
                    div(class="mb-3")
                        span(class="font-weight-bold") Tiêu đề: 
                        span #{role.title}

                    div(class="mb-3")
                        span(class="font-weight-bold") Trạng thái: 
                        if !role.deleted
                            span.badge.bg-success.text-white.ml-2 Hoạt động
                        else
                            span.badge.bg-danger.text-white.ml-2 Đã xóa

                    div(class="mb-3")
                        div(class="font-weight-bold mb-1") Mô tả:
                        div(class="p-3 bg-light border rounded") !{role.description || "<i>Không có mô tả</i>"}

                    //- Log hệ thống (Đã đồng bộ với Product)
                    
                    div(class="mt-4 pt-3 border-top")
                        if role.createdBy && role.createdBy.account_id
                            div <b>Người tạo:</b> #{role.createdBy.account_id.fullname}
                            div.small.text-muted #{moment(role.createdBy.createdAt).format('DD/MM/YYYY HH:mm')}
                        else
                            div <b>Người tạo:</b> <i>Không có thông tin</i>
                    
                        div(class="mt-3")
                            if role.updatedBy && role.updatedBy.length > 0
                                b Lịch sử cập nhật:
                                each item in role.updatedBy
                                    if item.account_id
                                        div(class="small border-bottom py-1 d-flex justify-content-between")
                                            span #{item.account_id.fullname}
                                            span.text-muted #{moment(item.updatedAt).fromNow()}
                            else 
                                div <b>Lịch sử cập nhật:</b> <i>Chưa có cập nhật nào</i>
            //- Cụm nút bấm
            div(class="mt-4")
                if(role.permissions.includes('role_edit'))
                    a(href=`${prefixAdmin}/roles/edit/${role._id}` class="btn btn-warning btn-sm mr-2") Chỉnh sửa
                a(href=`${prefixAdmin}/roles` class="btn btn-secondary btn-sm") Quay lại

        else
            .alert.alert-warning Vai trò không tồn tại!
            a(href=`${prefixAdmin}/roles` class="btn btn-secondary btn-sm") Quay lại