extends ../../layouts/default.pug
include ../../mixins/show-alert.pug
block main
    +alert-success(5000)
    h1  DANH SÁCH NHÓM QUYỀN
    
    .card.mb-3
    .card-header 
        .card-body 
            .row
                .col-2
                    a(
                        href=`${prefixAdmin}/roles/create`
                        class="btn btn-outline-success"
                    ) + Thêm mới
    .card.mb-3
        .card-header Danh sách nhóm quyền
        .card-body
            table(class="table table-hover table-sm" check-box-multi)
                thead
                    tr
                    th STT
                    th Tiêu đề
                    th Mô tả ngắn
                    th Hành động
                tbody
                    each item, index in roles 
                        tr
                        td #{index+1}
                        td #{item.title}
                        td !{item.description}
                        td
                            a(href=`${prefixAdmin}/roles/details/${item._id}` class="btn btn-info btn-sm") Chi tiết
                            a(href=`${prefixAdmin}/roles/edit/${item._id}` class="btn btn-warning btn-sm") Sửa
                            button(class="btn btn-danger btn-sm ml-1" button-delete idDel=item._id) Xóa
    form(
        action=""
        method="POST"
        form-delete
        data-path=`${prefixAdmin}/roles/delete`
        )