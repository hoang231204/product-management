extends ../../layouts/default.pug
block main 
    h1 Thùng rác
    .card.mb-3
        .card-header Thùng rác bài viết
            .card-body
                table(class="table table-hover table-sm")
                    thead
                        tr
                            th STT
                            th Hình ảnh
                            th Tiêu đề
                            th Trạng thái
                            th Người xóa
                            th Hoạt động
                    tbody
                        each item, index in posts
                            tr
                                td #{index+1}
                                td
                                    img( src=item.thumbnail, alt="Bài viết 1",width="100px",height="auto")
                                td #{item.title}
                                td
                                    if item.status == 'active'
                                        a(href="javascript:;" class="badge badge-success" ) Hoạt động
                                    else if item.status == 'inactive'
                                        a(href="javascript:;" class="badge badge-danger" ) Không hoạt động
                                    else if item.status == 'pending'
                                        a(href="javascript:;" class="badge badge-warning" ) Đang chờ
                                td  
                                    #{item.deletedBy.account_id.fullname}
                                    #{moment(item.deletedBy.deletedAt).format('DD/MM/YYYY HH:mm:ss')}
                                td
                                    button(class="btn btn-success btn-sm" button-restore data-id= item._id) Khôi phục
                                    button(class="btn btn-danger btn-sm ml-1" button-hard-delete data-id=item._id) Xóa
    form(
      action="",
      method="POST"
      form-hard-delete
      data-path = `${prefixAdmin}/posts/recycle-bin/hard-delete`
    )
    form(
      action="",
      method="POST"
      form-restore 
      data-path = `${prefixAdmin}/posts/recycle-bin/restore`
    )
    script(src="/admin/js/recycleBin.js") 