extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-error(5000)
    +alert-success(5000)

    .container.my-5
        .card.shadow-sm
            .card-header.bg-white.py-3
                h1.mb-0.h3.font-weight-bold #{post.title}
            
            .card-body
                //- Hình ảnh
                if post.thumbnail
                    .text-center.mb-4
                        img(src=post.thumbnail class="img-fluid rounded border" style="max-height: 350px; object-fit: cover;")

                //- Thông tin cơ bản
                .row.mb-4
                    .col-md-4
                        p.mb-2 <b>Danh mục:</b> 
                            span #{post.category_id ? post.category_id.title : 'Chưa có danh mục'}
                    .col-md-4
                        p.mb-2 <b>Trạng thái:</b> 
                            if post.status === 'active'
                                span.badge.bg-success Hoạt động
                            else
                                span.badge.bg-danger Dừng hoạt động
                    .col-md-4
                        p.mb-2 <b>Loại bài:</b> 
                            if post.featured === '1'
                                span.badge.bg-warning Nổi bật
                            else
                                span.badge.bg-secondary Thường

                //- Mô tả & Nội dung
                .mb-4
                    h5.font-weight-bold Mô tả:
                    .p-3.bg-light.border.rounded !{post.description}
                
                .mb-4
                    h5.font-weight-bold Nội dung:
                    .p-3.bg-light.border.rounded !{post.content}

                //- Thông tin người tạo và cập nhật
                .row.mt-4.pt-3.border-top
                    .col-md-6
                        if post.createdBy && post.createdBy.account_id
                            p.mb-1 <b>Người tạo:</b> #{post.createdBy.account_id.fullname}
                            p.small.text-muted #{moment(post.createdBy.createdAt).format('DD/MM/YYYY HH:mm:ss')}
                    
                    .col-md-6
                        if post.updatedBy && post.updatedBy.length > 0
                            - var lastUpdate = post.updatedBy[post.updatedBy.length - 1]
                            if lastUpdate.account_id
                                p.mb-1 <b>Cập nhật gần nhất bởi:</b> #{lastUpdate.account_id.fullname}
                                p.small.text-muted #{moment(lastUpdate.updatedAt).format('DD/MM/YYYY HH:mm:ss')}
                        else 
                            p.mb-1 <b>Lịch sử cập nhật:</b> Chưa có dữ liệu

                //- Nút bấm
                .mt-4.d-flex.justify-content-end
                    a(href=`${prefixAdmin}/posts` class="btn btn-secondary mr-2") Quay lại
                    if role.permissions.includes("post_edit")
                        a(href=`${prefixAdmin}/posts/edit/${post._id}` class="btn btn-warning") Sửa bài viết