extends ../../layouts/default.pug
include ../../mixins/show-alert.pug
include ../../mixins/select-tree.pug

block main
    +alert-error(5000)
    +alert-success(5000)
    
    .container.my-5
        .card.form-card
            h1(class="mb-4 text-center") CHỈNH SỬA BÀI VIẾT
            
            form(
                action=`${prefixAdmin}/posts/edit/${post._id}?_method=PATCH` 
                id="form-edit-post" 
                method="POST" 
                enctype="multipart/form-data" 
                form-upload
            )
                .row
                    //- Cột trái: Nội dung chính
                    .col-md-8
                        .form-group.mb-3
                            label(for="title" class="font-weight-bold") Tiêu đề *
                            input(
                                type="text"
                                class="form-control"
                                id="title"
                                name="title"
                                value=post.title
                                required 
                            )
                        
                        .form-group.mb-3
                            label(for="desc" class="font-weight-bold") Mô tả
                            textarea(
                                class="form-control textarea-mce"
                                id="desc"
                                name="description"
                                rows="5"
                            )= post.description

                        .form-group.mb-3
                            label(for="content" class="font-weight-bold") Nội dung
                            textarea(
                                class="form-control textarea-mce"
                                id="content"
                                name="content"
                                rows="10"
                            )= post.content

                    //- Cột phải: Cấu hình
                    .col-md-4
                        .form-group.mb-3
                            label(for="category" class="font-weight-bold") Danh mục
                            select(
                                name="category"
                                id="category"
                                class="form-control"
                            )
                                option(value=categoryId) #{categoryTitle}
                                if (categoryTree)
                                    +select-tree(categoryTree)

                        .form-group.mb-3(upload-image)
                            label(for="thumbnail" class="font-weight-bold") Ảnh đại diện
                            input(
                                type="file"
                                class="form-control-file d-block mb-2"
                                id="thumbnail"
                                name="thumbnail"
                                accept="image/*"
                                upload-image-input
                            )
                            div(class="box-image border p-2 text-center rounded")
                                img(
                                    src=post.thumbnail
                                    upload-image-preview
                                    class="image-preview img-fluid"
                                    style="max-height: 150px;"
                                )
                                button(
                                    type="button"
                                    class="btn-remove-image btn btn-danger btn-sm mt-2"
                                    aria-label="Remove image"
                                ) Xóa ảnh

                        .form-group.mb-3
                            label(for="position" class="font-weight-bold") Vị trí
                            input(
                                type="number"
                                class="form-control"
                                id="position"
                                name="position"
                                value=post.position
                                min="1"
                            )

                        .form-group.mb-3
                            label.d-block.font-weight-bold Bài viết nổi bật
                            .form-check.form-check-inline
                                input(type="radio" class="form-check-input" id="featured" name="featured" value="1" checked=(post.featured === "1"))
                                label(class="form-check-label" for="featured") Nổi bật
                            .form-check.form-check-inline
                                input(type="radio" class="form-check-input" id="notFeatured" name="featured" value="0" checked=(post.featured === "0"))
                                label(class="form-check-label" for="notFeatured") Thường

                        .form-group.mb-4
                            label.d-block.font-weight-bold Trạng thái
                            .form-check.form-check-inline
                                input(type="radio" class="form-check-input" id="statusActive" name="status" value="active" checked=(post.status === "active"))
                                label(class="form-check-label" for="statusActive") Hoạt động
                            .form-check.form-check-inline
                                input(type="radio" class="form-check-input" id="statusInactive" name="status" value="inactive" checked=(post.status === "inactive"))
                                label(class="form-check-label" for="statusInactive") Dừng hoạt động
                            .form-check.form-check-inline
                                input(type="radio" class="form-check-input" id="statusPending" name="status" value="pending" checked=(post.status === "pending"))
                                label(class="form-check-label" for="statusPending") Đang chờ

                //- Nút submit
                .text-center.mt-4
                    button(type="submit" class="btn btn-primary px-5 mr-2") Cập nhật bài viết
                    a(href=`${prefixAdmin}/posts` class="btn btn-secondary px-4") Quay lại