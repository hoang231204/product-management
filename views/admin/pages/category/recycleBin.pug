extends ../../layouts/default.pug
block main 
    h1 Thùng rác
    .card.mb-3
        .card-header Thùng rác danh mục
        .card-body
            table(class="table table-hover table-sm")
                thead
                    tr
                    th STT
                    th Hình ảnh
                    th Tiêu đề
                    th Thời gian xóa
                    th Hoạt động
                tbody
                    each item, index in categories
                        tr
                        td #{index+1}
                        td
                            img( src=item.thumbnail, alt="Sản phẩm 1",width="100px",height="auto")
                        td #{item.title}
                        td #{item.deleteAt}
                        td
                            button(class="btn btn-success btn-sm" button-restore data-id= item.id) Khôi phục
                            button(class="btn btn-danger btn-sm ml-1" button-hard-delete data-id=item.id) Xóa
    form(
      action="",
      method="POST"
      form-hard-delete
      data-path = `${prefixAdmin}/categories/recycleBin/hard-delete`
    )
    form(
      action="",
      method="POST"
      form-restore 
      data-path = `${prefixAdmin}/categories/recycleBin/restore`
    )
    script(src="/admin/js/recycleBin.js") 