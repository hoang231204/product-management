extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-error(5000)
    +alert-success(5000)

    .container.my-5
        .detail-card
            h1.mb-4.text-primary #{product.title}
            .row
                .col-md-4
                    div(class="border-0 text-center")
                        img(src=product.thumbnail class="img-fluid img-detail mb-3" style="max-height: 300px; object-fit: cover;")
                    .info-box.mt-3
                        p <b>Danh mục:</b> #{product.category_id ? product.category_id.title : "Chưa có"}
                        p <b>Giá:</b> <span class="text-success font-weight-bold">#{product.price}$</span>
                        p <b>Trạng thái:</b> #{product.status === 'active' ? "Hoạt động" : "Dừng"}
                        p <b>Nổi bật:</b> #{product.featured === '1' ? "Có" : "Không"}

                .col-md-8
                    h5.mb-3 Mô tả chi tiết:
                    .description-box
                        | !{product.description}
                    
                    .mt-4.pt-3.border-top
                        h5.mb-3 Lịch sử cập nhật:
                        if product.updatedBy && product.updatedBy.length > 0
                            each item in product.updatedBy
                                if item.account_id
                                    .history-item
                                        div <b>#{item.account_id.fullname}</b> đã cập nhật
                                        div.small.text-muted #{moment(item.updatedAt).format('DD/MM/YYYY HH:mm:ss')}
                        else
                            p.text-muted Chưa có cập nhật nào.
            .mt-4
                if role.permissions.includes("product_edit")
                    a(href=`${prefixAdmin}/products/edit/${product._id}` class="btn btn-warning mr-2") 
                        i.fa.fa-edit.mr-1 
                        | Sửa sản phẩm
                a(href=`${prefixAdmin}/products` class="btn btn-secondary") 
                    i.fa.fa-arrow-left.mr-1 
                    | Quay lại danh sách