extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-error(5000)
    +alert-success(5000)

    .container.my-5
        h1.mb-4 #{product.title}
        div(class="border rounded p-2 text-center")
            img(src=product.thumbnail class="img-fluid mb-3" style="max-height: 300px; object-fit: cover;")
        div(class="mb-2")
            b Danh mục: 
            if product.category_id
                span #{product.category_id.title}
            else
                span.text-muted Chưa có danh mục
        div(class="mb-2")
            b Trạng thái: 
            if product.featured === '1'
                span.badge.bg-success Nổi bật
            else
                span.badge.bg-secondary Thường
        div(class="mb-2") <b>Giá:</b> #{product.price}$
        div(class="mb-2")
            b Trạng thái: 
            if product.status === 'active'
                span.badge.bg-success Hoạt động
            else
                span.badge.bg-danger Dừng hoạt động
        div(class="mb-3")
            b Mô tả:
            div(class="mt-1 p-2 bg-light border rounded") !{product.description}
        
        div(class="mt-4 pt-2 border-top")
            if product.createdBy && product.createdBy.account_id
                div <b>Người tạo:</b> #{product.createdBy.account_id.fullname}
                div.small.text-muted #{moment(product.createdBy.createdAt).format('DD/MM/YYYY HH:mm:ss')}
        
        div(class="mt-3")
            if product.updatedBy && product.updatedBy.length > 0
                b Lịch sử cập nhật:
                each item in product.updatedBy
                    if item.account_id
                        div(class="small border-bottom py-1")
                            span #{item.account_id.fullname} 
                            span.text-muted.ml-2 - #{moment(item.updatedAt).format('DD/MM/YYYY HH:mm:ss')}
            else 
                div(class="mt-3")
                    b Lịch sử cập nhật:
                    div Chưa có cập nhật nào
        div(class="mt-4")
            if role.permissions.includes("product_edit")
                a(href=`${prefixAdmin}/products/edit/${product._id}` class="btn btn-warning btn-sm mr-2") Sửa
            a(href=`${prefixAdmin}/products` class="btn btn-secondary btn-sm") Quay lại