extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-error(5000)
    +alert-success(5000)

    .container.my-5
        h1.mb-4 #{product.title}
        
        .row
            //- Ảnh bên trái
            .col-4
                div(class="border rounded p-2 text-center")
                    img(src=product.thumbnail class="img-fluid")
            
            //- Thông tin bên phải
            .col-8
                div(class="mb-2") <b>Giá:</b> #{product.price}$
                
                div(class="mb-2")
                    b Trạng thái: 
                    if product.status === 'active'
                        span.badge.bg-success Hoạt động
                    else
                        span.badge.bg-danger Dừng hoạt động

                div(class="mb-3")
                    b Mô tả:
                    div(class="mt-1 p-2 bg-light border rounded") !{product.description}

                //- Phần Log: Người tạo
                if product.createdBy && product.createdBy.account_id
                    div(class="mt-4 pt-2 border-top")
                        div <b>Người tạo:</b> #{product.createdBy.account_id.fullname}
                        div.small.text-muted #{moment(product.createdBy.createdAt).format('DD/MM/YYYY HH:mm')}

                //- Phần Log: Lịch sử cập nhật
                if product.updatedBy && product.updatedBy.length > 0
                    div(class="mt-3")
                        b Lịch sử cập nhật:
                        each item in product.updatedBy
                            if item.account_id
                                div(class="small border-bottom py-1")
                                    span #{item.account_id.fullname} 
                                    span.text-muted.ml-2 - #{moment(item.updatedAt).fromNow()}

        //- Nút bấm
        div(class="mt-4")
            if role.permissions.includes("product_edit")
                a(href=`${prefixAdmin}/products/edit/${product._id}` class="btn btn-warning btn-sm mr-2") Sửa
            a(href=`${prefixAdmin}/products` class="btn btn-secondary btn-sm") Quay lại