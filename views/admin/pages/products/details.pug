extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-error(5000)
    +alert-success(5000)
    
    .container-fluid.mt-4
        .row
            .col-md-8
                .card.shadow-sm
                    .card-header.bg-primary.text-white
                        h4.mb-0 Chi tiết sản phẩm
                    
                    .card-body
                        // Hình ảnh sản phẩm
                        .row.mb-4
                            .col-md-12.text-center
                                if product.thumbnail
                                    img(src=product.thumbnail alt=product.title class="img-fluid rounded" style="max-height: 400px; object-fit: cover; max-width: 100%;")
                                else
                                    .bg-light.d-flex.align-items-center.justify-content-center.rounded(style="height: 400px;")
                                        p.text-muted Không có hình ảnh
                        
                        // Tiêu đề
                        .mb-4
                            h5.text-uppercase.border-bottom.pb-2.mb-3
                                i.fas.fa-heading.me-2
                                | Tiêu đề sản phẩm
                            p.fs-5.text-dark= product.title
                        
                        // Slug
                        .mb-4
                            h5.text-uppercase.border-bottom.pb-2.mb-3
                                i.fas.fa-link.me-2
                                | Slug
                            p.text-muted= product.slug
                        
                        // Mô tả
                        .mb-4
                            h5.text-uppercase.border-bottom.pb-2.mb-3
                                i.fas.fa-align-left.me-2
                                | Mô tả
                            .bg-light.p-3.rounded
                                p.text-dark!= product.description
                        
                        // Giá và Giảm giá
                        .mb-4
                            h5.text-uppercase.border-bottom.pb-2.mb-3
                                i.fas.fa-tag.me-2
                                | Thông tin giá
                            
                            .row
                                .col-md-4
                                    .card.border-0.bg-light
                                        .card-body
                                            label.fw-bold.d-block Giá gốc
                                            p.fs-5.text-primary.fw-bold.mb-0
                                                = product.price.toLocaleString('vi-VN')
                                                |  đ
                                
                                .col-md-4
                                    .card.border-0.bg-light
                                        .card-body
                                            label.fw-bold.d-block % Giảm giá
                                            p.fs-5.text-danger.fw-bold.mb-0= product.discountPercentage + '%'
                                
                                .col-md-4
                                    .card.border-0.bg-light
                                        .card-body
                                            label.fw-bold.d-block Giá khuyến mãi
                                            - const discountedPrice = product.price * (1 - product.discountPercentage / 100)
                                            p.fs-5.text-success.fw-bold.mb-0
                                                = discountedPrice.toLocaleString('vi-VN')
                                                |  đ
                        
                        // Kho hàng
                        .mb-4
                            h5.text-uppercase.border-bottom.pb-2.mb-3
                                i.fas.fa-warehouse.me-2
                                | Quản lý kho
                            
                            .row
                                .col-md-6
                                    .card.border-0.bg-light
                                        .card-body
                                            label.fw-bold.d-block Số lượng tồn kho
                                            if product.stock > 10
                                                p.fs-5.text-success.fw-bold.mb-0= product.stock + ' sản phẩm'
                                            else if product.stock > 0
                                                p.fs-5.text-warning.fw-bold.mb-0= product.stock + ' sản phẩm'
                                            else
                                                p.fs-5.text-danger.fw-bold.mb-0 Hết hàng
                                
                                .col-md-6
                                    .card.border-0.bg-light
                                        .card-body
                                            label.fw-bold.d-block Vị trí
                                            p.fs-5.text-dark.fw-bold.mb-0= product.position
                        
                        // Trạng thái
                        .mb-4
                            h5.text-uppercase.border-bottom.pb-2.mb-3
                                i.fas.fa-flag.me-2
                                | Trạng thái
                            
                            .row
                                .col-md-6
                                    .card.border-0.bg-light
                                        .card-body
                                            label.fw-bold.d-block Trạng thái hoạt động
                                            if product.status === 'active'
                                                span.badge.bg-success.fs-6 Hoạt động
                                            else
                                                span.badge.bg-secondary.fs-6 Không hoạt động
                                
                                .col-md-6
                                    .card.border-0.bg-light
                                        .card-body
                                            label.fw-bold.d-block Trạng thái xóa
                                            if product.delete === true
                                                span.badge.bg-danger.fs-6 Đã xóa
                                            else
                                                span.badge.bg-success.fs-6 Còn tồn tại
                        
                        // Thời gian
                        .mb-4
                            h5.text-uppercase.border-bottom.pb-2.mb-3
                                i.fas.fa-clock.me-2
                                | Thời gian
                            
                            .row
                                .col-md-6
                                    label.fw-bold.d-block Tạo lúc
                                    p.text-muted= new Date(product.createdAt).toLocaleString('vi-VN')
                                
                                .col-md-6
                                    label.fw-bold.d-block Cập nhật lúc
                                    p.text-muted= new Date(product.updatedAt).toLocaleString('vi-VN')
                            
                            if product.deleteAt
                                .row.mt-3
                                    .col-md-6
                                        label.fw-bold.d-block Xóa lúc
                                        p.text-muted= new Date(product.deleteAt).toLocaleString('vi-VN')
            
            // Sidebar - Thao tác
            .col-md-4
                .card.shadow-sm.sticky-top(style="top: 20px;")
                    .card-header.bg-dark.text-white
                        h5.mb-0 Thao tác
                    
                    .card-body
                        a(href=`${prefixAdmin}/products/edit/${product._id}` class="btn btn-warning btn-sm w-100 mb-2")
                            i.fas.fa-edit.me-2
                            | Chỉnh sửa
                        
                        if product.status === 'active'
                            a(href=`${prefixAdmin}/products/change-status/inactive/${product._id}?_method=PATCH` class="btn btn-secondary btn-sm w-100 mb-2" onclick="return confirm('Bạn chắc chắn muốn vô hiệu hóa sản phẩm này?')")
                                i.fas.fa-ban.me-2
                                | Vô hiệu hóa
                        else
                            a(href=`${prefixAdmin}/products/change-status/active/${product._id}?_method=PATCH` class="btn btn-success btn-sm w-100 mb-2" onclick="return confirm('Bạn chắc chắn muốn kích hoạt sản phẩm này?')")
                                i.fas.fa-check.me-2
                                | Kích hoạt
                        
                        a(href=`${prefixAdmin}/products/delete/${product._id}?_method=DELETE` class="btn btn-danger btn-sm w-100 mb-2" onclick="return confirm('Bạn chắc chắn muốn xóa sản phẩm này?')")
                            i.fas.fa-trash.me-2
                            | Xóa vào thùng rác
                        
                        hr
                        
                        a(href=`${prefixAdmin}/products` class="btn btn-info btn-sm w-100")
                            i.fas.fa-arrow-left.me-2
                            | Quay lại danh sách
                
                // Thông tin bổ sung
                .card.shadow-sm.mt-3
                    .card-header.bg-secondary.text-white
                        h5.mb-0 Thông tin ID
                    
                    .card-body.small
                        label.fw-bold Mã sản phẩm:
                        p.text-muted.text-break= product._id
