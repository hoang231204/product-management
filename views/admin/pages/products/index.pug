extends ../../layouts/default.pug
include ../../mixins/filter-status.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug
include ../../mixins/change-multi.pug
include ../../mixins/show-alert.pug
include ../../mixins/sort.pug
block main
    if(role.permissions.includes("product_view"))
        +alert-success(5000)
        .container.my-3
            .card.mb-3
                h3.text-center Quản lý sản phẩm
                .card-header Bộ lọc và Tìm kiếm
                    .card-body
                        .row.align-items-center.mb-3
                            .col-lg-8
                                +boxFilter(filterStatus)
                            .col-lg-4
                                +boxSearch(keyword)
                .card-header Sắp xếp
                    .card-body
                        .row.align-items-center.mb-3.action-box
                            .col-lg-4
                                .d-flex.align-items-center
                                    div(style="flex-grow: 1")
                                        +boxSort('product')
                .card-header Thay đổi
                    .card-body
                        .row.align-items-center.action-box.mb-3
                            .col-lg-8
                                if(role.permissions.includes("product_edit"))
                                    +boxChange(`${prefixAdmin}/products/change-multi?_method=PATCH`, 'product')
                            .col-lg-3.text-lg-right
                                if(role.permissions.includes("product_create"))
                                    a(href=`${prefixAdmin}/products/create` class="btn btn-success")
                                        i.fa.fa-plus.mr-2
                                        | Thêm mới
            .card.mb-3
                .card-header Danh sách sản phẩm
                    .card-body
                        .table-responsive
                            table(class="table table-hover table-sm" check-box-multi)
                                thead
                                    tr.text-center
                                        th
                                            input(type="checkbox" name="checkAll")
                                        th STT
                                        th Hình ảnh
                                        th Tiêu đề
                                        th Danh mục
                                        th Giá
                                        th Vị trí
                                        th Trạng thái
                                        th Người tạo
                                        th Người sửa
                                        th Hành động
                                tbody
                                    each item, index in products
                                        tr.text-center
                                            td
                                                input(
                                                    type="checkbox"
                                                    name="id"
                                                    value=item.id
                                                    )
                                            td #{index+1+objectPagination.skipPage}
                                            td
                                                img( src=item.thumbnail, alt=item.title,width="100px",height="auto")
                                            td.font-weight-bold #{item.title}
                                            td #{item.category_id ? item.category_id.title : 'Chưa có danh mục'}
                                            td #{item.price}$
                                            td
                                                input(
                                                    type="number"
                                                    value=item.position 
                                                    style="width:50px"
                                                    min="1"
                                                    name="position"
                                                )
                                            td
                                                if(role.permissions.includes("product_edit"))
                                                    if item.status == 'active'
                                                        a(
                                                            href="javascript:;" 
                                                            class="badge badge-success" 
                                                            button-change-status 
                                                            data-id=item._id  
                                                            data-status=item.status
                                                            data-next-status="inactive"
                                                            ) Hoạt động
                                                    else if item.status == 'inactive'
                                                        a(
                                                            href="javascript:;" 
                                                            class="badge badge-danger" 
                                                            button-change-status 
                                                            data-id=item._id  
                                                            data-status=item.status
                                                            data-next-status="active"
                                                            ) Không hoạt động
                                                    else if item.status == 'pending'
                                                        a(
                                                            href="javascript:;" 
                                                            class="badge badge-warning" 
                                                            button-change-status 
                                                            data-id=item._id  
                                                            data-status=item.status
                                                            data-next-status="active"
                                                            ) Đang chờ
                                                    else
                                                        a(
                                                            href="javascript:;" 
                                                            class="badge badge-secondary" 
                                                            button-change-status 
                                                            data-id=item._id  
                                                            data-status=item.status
                                                            data-next-status="active"
                                                            ) Sắp hết hàng
                                            td
                                                p #{item.createdBy.account_id.fullname}
                                                p #{moment(item.createdBy.createdAt).format('DD/MM/YYYY HH:mm:ss')}
                                            td
                                                if item.updatedBy && item.updatedBy.length > 0
                                                    p #{item.updatedBy[item.updatedBy.length - 1].account_id.fullname}
                                                    p #{moment(item.updatedBy[item.updatedBy.length - 1].updatedAt).format('DD/MM/YYYY HH:mm:ss')}
                                                else
                                                    p Chưa có cập nhật
                                            td
                                                .row.justify-content-center.gap-2
                                                    a(href=`${prefixAdmin}/products/details/${item._id}` class="btn btn-info btn-sm")
                                                        i.fas.fa-eye
                                                    <br>
                                                    if(role.permissions.includes("product_edit"))
                                                        a(href=`${prefixAdmin}/products/edit/${item._id}` class="btn btn-warning btn-sm")
                                                            i.fas.fa-edit
                                                    <br>    
                                                    if(role.permissions.includes("product_delete"))
                                                        button(class="btn btn-danger btn-sm" button-delete data-id=item._id)
                                                            i.fas.fa-trash
                        +pagination(objectPagination)
    form(
        action=""
        method="POST"
        form-change-status
        data-path=`${prefixAdmin}/products/change-status`
        ) 
    form(
        action=""
        method="POST"
        form-delete
        data-path=`${prefixAdmin}/products/delete`
         )
    
    script(src="/admin/js/change-multi.js") 