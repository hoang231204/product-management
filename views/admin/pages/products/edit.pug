extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-error(5000)
    +alert-success(5000)
    h1(class="mb-4") Chỉnh sửa sản phẩm
    
    form(action=`${prefixAdmin}/products/edit/${product._id}?_method=PATCH` id="form-edit-product" method="POST" enctype="multipart/form-data" form-edit)
        
        // Tiêu đề (Title)
        div(class="form-group")
            label(for="title") Tiêu đề
            input(
                type="text"
                class="form-control"
                id="title"
                name="title"
                value=product.title
                required 
            )
        
        // Mô tả (Description)
        div(class="form-group")
            label(for="desc") Mô tả
            textarea(
                class="form-control textarea-mce"
                id="desc"
                name="description"
                rows="5"
            )= product.description
        
        // Giá (Price)
        div(class="form-group")
            label(for="price") Giá
            input(
                type="number"
                class="form-control"
                id="price"
                name="price"
                value=product.price
                min="0"
            )
        
        // % Giảm giá (Discount Percentage)
        div(class="form-group")
            label(for="discount") % Giảm giá
            input(
                type="number"
                class="form-control"
                id="discount"
                name="discountPercentage"
                value=product.discountPercentage
                min="0"
            )
        
        // Số lượng (Stock)
        div(class="form-group")
            label(for="stock") Số lượng
            input(
                type="number"
                class="form-control"
                id="stock"
                name="stock"
                value=product.stock
                min="0"
            )
        
        // Ảnh (Thumbnail)
        div(class="form-group" upload-image)
            label(for="thumbnail") Ảnh
            input(
                type="file"
                class="form-control-file"
                id="thumbnail"
                name="thumbnail"
                accept="image/*"
                upload-image-input
            )
            div(class="box-image")
                img(
                    src=product.thumbnail
                    upload-image-preview
                    class="image-preview"
                )
                button(
                    type="button"
                    class="btn-remove-image"
                    aria-label="Remove image"
                ) ×
        
        // Vị trí (Position)
        div(class="form-group")
            label(for="position") Vị trí
            input(
                type="number"
                class="form-control"
                id="position"
                name="position"
                value=product.position
                min="1"
            )
        
        // Trạng thái (Status)
        div(class="form-group form-check form-check-inline")
            input(
                type="radio"
                class="form-check-input"
                id="statusActive"
                name="status"
                value="active"
                checked=(product.status === "active")
            )
            label(class="form-check-label" for="statusActive") Hoạt động
        
        div(class="form-group form-check form-check-inline")
            input(
                type="radio"
                class="form-check-input"
                id="statusInactive"
                name="status"
                value="inactive"
                checked=(product.status === "inactive")
            )
            label(class="form-check-label" for="statusInactive") Dừng hoạt động
        
        // Nút submit
        div(class="form-group")
            button(type="submit" class="btn btn-primary") Cập nhật sản phẩm
            a(href=`${prefixAdmin}/products` class="btn btn-secondary") Quay lại