extends ../../layouts/default.pug
include ../../mixins/show-alert.pug
include ../../mixins/select-tree.pug

block main
    +alert-error(5000)
    +alert-success(5000)

    .container.my-5
        .card.form-card
            h2(class="mb-4 text-center") Chỉnh sửa sản phẩm
            form(action=`${prefixAdmin}/products/edit/${product._id}?_method=PATCH` id="form-edit-product" method="POST" enctype="multipart/form-data" form-upload)
                .row
                    .col-12
                        .form-group
                            label Tiêu đề
                            input(type="text" class="form-control" name="title" value=product.title required)
                .row
                    .col-md-6
                        .form-group
                            label Danh mục
                            .action-box
                                select(name="category_id" class="form-control")
                                    option(value=categoryId) #{categoryTitle}
                                    if (categoryTree)
                                        +select-tree(categoryTree)
                    .col-md-6
                        .form-group
                            label Vị trí
                            .action-box
                                input(type="number" class="form-control" name="position" value=product.position min="1")
                .row   
                    .col-md-4
                        .form-group
                            label Giá
                            input(type="number" class="form-control" name="price" value=product.price min="0")
                    .col-md-4
                        .form-group
                            label % Giảm giá
                            input(type="number" class="form-control" name="discountPercentage" value=product.discountPercentage min="0")
                    .col-md-4
                        .form-group
                            label Số lượng
                            input(type="number" class="form-control" name="stock" value=product.stock min="0")
                .row
                    .col-12
                        .form-group
                            label Mô tả
                            textarea(class="form-control textarea-mce" name="description" rows="5")= product.description
                .row
                    .col-md-6
                        .form-group(upload-image)
                            label Ảnh sản phẩm
                            input(type="file" class="form-control-file" name="thumbnail" accept="image/*" upload-image-input)
                            .box-image
                                img(src=product.thumbnail upload-image-preview class="image-preview")
                                button(type="button" class="btn-remove-image") ×

                    .col-md-6
                        .row
                            .col-12.mb-3
                                label Trạng thái
                                .d-flex.flex-wrap.gap-2
                                    .form-check.form-check-inline
                                        input(type="radio" class="form-check-input" id="statusActive" name="status" value="active" checked=(product.status === "active"))
                                        label(for="statusActive" class="form-check-label") Hoạt động
                                    .form-check.form-check-inline
                                        input(type="radio" class="form-check-input" id="statusInactive" name="status" value="inactive" checked=(product.status === "inactive"))
                                        label(for="statusInactive" class="form-check-label") Dừng
                                    .form-check.form-check-inline
                                        input(type="radio" class="form-check-input" id="statusPending" name="status" value="pending" checked=(product.status === "pending"))
                                        label(for="statusPending" class="form-check-label") Đang chờ
                                    .form-check.form-check-inline
                                        input(type="radio" class="form-check-input" id="statusLowStock" name="status" value="low-stock" checked=(product.status === "low-stock"))
                                        label(for="statusLowStock" class="form-check-label") Hết hàng

                            .col-12
                                label Nổi bật
                                .d-flex.gap-3
                                    .form-check.form-check-inline
                                        input(type="radio" class="form-check-input" id="featured" name="featured" value="1" checked=(product.featured === "1"))
                                        label(for="featured" class="form-check-label") Có
                                    .form-check.form-check-inline
                                        input(type="radio" class="form-check-input" id="notFeatured" name="featured" value="0" checked=(product.featured === "0"))
                                        label(for="notFeatured" class="form-check-label") Không
                .text-right.mt-4
                    button(type="submit" class="btn btn-primary px-5 mr-2") Cập nhật
                    a(href=`${prefixAdmin}/products` class="btn btn-secondary") Quay lại