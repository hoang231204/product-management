extends ../../layouts/default.pug
block main 
    .card.mb-3
        .card-header Thùng rác sản phẩm
        .card-body
            table(class="table table-hover table-sm")
                thead
                    tr.text-center
                        th STT
                        th Hình ảnh
                        th Tiêu đề
                        th Trạng thái
                        th Người xóa
                        th Hoạt động
                tbody
                    each item, index in products
                        tr.text-center
                            td #{index+1}
                            td
                                img( src=item.thumbnail, alt="Sản phẩm 1",width="100px",height="auto")
                            td #{item.title}
                            td
                                if item.status == 'active'
                                    a(href="javascript:;" class="badge badge-success" ) Hoạt động
                                else if item.status == 'inactive'
                                    a(href="javascript:;" class="badge badge-danger" ) Không hoạt động
                                else if item.status == 'pending'
                                    a(href="javascript:;" class="badge badge-warning" ) Đang chờ
                                else
                                    a(href="javascript:;" class="badge badge-secondary") Sắp hết
                            td  
                                #{item.deletedBy.account_id.fullname}
                                #{moment(item.deletedBy.deletedAt).format('DD/MM/YYYY HH:mm:ss')}
                            td
                                .row.justify-content-center
                                    button(class="btn btn-success btn-sm" button-restore data-id= item._id)
                                        i.fas.fa-undo
                                    button(class="btn btn-danger btn-sm ml-1" button-hard-delete data-id=item._id)
                                        i.fas.fa-trash
    form(
      action="",
      method="POST"
      form-hard-delete
      data-path = `${prefixAdmin}/products/recycle-bin/hard-delete`
    )
    form(
      action="",
      method="POST"
      form-restore 
      data-path = `${prefixAdmin}/products/recycle-bin/restore`
    )
    script(src="/admin/js/recycleBin.js") 