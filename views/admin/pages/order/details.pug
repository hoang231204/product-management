extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-error(5000)
    +alert-success(5000)

    if(role.permissions.includes('order_view'))
        .container.my-5
            h1.mb-4 Chi tiết đơn hàng
            
            //- Trạng thái & Lịch sử
            .row
                .col-md-6
                    .card.shadow-sm.mb-4
                        .card-header.font-weight-bold Trạng thái đơn hàng
                        .card-body
                            case order.status
                                when 'pending'
                                    div.alert.alert-warning.mb-0 Đang chờ
                                when 'confirmed'
                                    div.alert.alert-info.mb-0 Đã xác nhận
                                when 'shipped'
                                    div.alert.alert-primary.mb-0 Đang giao
                                when 'delivered'
                                    div.alert.alert-success.mb-0 Đã giao
                                default
                                    div.alert.alert-danger.mb-0 Người mua đã hủy
                            
                            div.mt-3
                                b Thời gian đặt hàng:
                                span.text-muted.ml-2 #{moment(order.createdAt).format('DD/MM/YYYY HH:mm:ss')}

                .col-md-6
                    .card.shadow-sm.mb-4
                        .card-header.font-weight-bold Lịch sử cập nhật
                        .card-body.p-0
                            if order.updatedBy && order.updatedBy.length > 0
                                .table-responsive
                                    table.table.table-hover.mb-0
                                        each item in order.updatedBy
                                            if item.account_id
                                                tr
                                                    td.small.py-2
                                                        b #{item.account_id.fullname}
                                                        span.text-muted.ml-2 - #{moment(item.updatedAt).format('DD/MM/YYYY HH:mm:ss')}
                            else 
                                p.p-3.text-muted Chưa có cập nhật nào

            //- Thông tin người mua
            .card.shadow-sm.mb-4
                .card-header.font-weight-bold Thông tin người mua hàng
                .card-body
                    table(class="table table-bordered mb-0")
                        tbody
                            tr
                                td(style="width: 25%;" class="font-weight-bold text-center") Họ tên
                                td #{order.userInfor.fullname}
                            tr
                                td(class="font-weight-bold text-center") Số điện thoại
                                td #{order.userInfor.phone}
                            tr
                                td(class="font-weight-bold text-center") Địa chỉ
                                td #{order.userInfor.address}

            //- Thông tin sản phẩm
            .card.shadow-sm.mb-5
                .card-header.font-weight-bold Danh sách sản phẩm
                .card-body
                    if order && order.products && order.products.length > 0
                        table(class="table table-hover align-middle text-center")
                            thead(class="thead-light")
                                tr
                                    th STT
                                    th Hình ảnh
                                    th Tên sản phẩm
                                    th Giá
                                    th Số lượng
                                    th Tổng tiền
                            tbody
                                each item, index in order.products
                                    tr
                                        td #{index + 1}
                                        td
                                            if item.product_id
                                                img(src=item.product_id.thumbnail, alt=item.product_id.title, width="80px" class="rounded")
                                        td.text-left
                                            if item.product_id
                                                b #{item.product_id.title}
                                            else
                                                span.text-danger Sản phẩm không tồn tại
                                        td #{item.priceNew.toLocaleString()}$
                                        td #{item.quantity}
                                        td.font-weight-bold #{(item.priceNew * item.quantity).toLocaleString()}$
                        
                        .text-right.mt-3.p-3.bg-light.rounded
                            h4.mb-0 Tổng giá trị đơn hàng: 
                                span.text-primary.font-weight-bold #{order.totalPrice.toLocaleString()}$
                    else
                        p(class="text-center py-4") Không có sản phẩm nào trong đơn hàng.
            
            .text-center.mt-4
                a(href=`${prefixAdmin}/orders` class="btn btn-secondary px-4") Quay lại