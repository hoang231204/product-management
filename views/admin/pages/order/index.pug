extends ../../layouts/default.pug
include ../../mixins/show-alert.pug
include ../../mixins/filter-status.pug
include ../../mixins/search.pug
include ../../mixins/change-multi.pug
include ../../mixins/sort.pug
include ../../mixins/pagination.pug
block main
    +alert-success(3000)
    +alert-error(3000)
    if(role.permissions.includes("order_view"))
        h1.mb-4 Quản lý đơn hàng
        .card.mb-3
                .card-header Bộ lọc và Tìm kiếm
                    .card-body
                        .row
                            .col-6#filter-area
                                +boxFilter(filterStatus)

                            .col-5
                                +boxSearch(keyword)
                            .col-1 
                                a(href=`${prefixAdmin}/orders` class="btn btn-secondary") Reset  
        .card.mb-3
            .card-header Thay đổi
                .card-body 
                    .row
                        .col-12
                            if(role.permissions.includes("order_edit"))
                                +boxChange(`${prefixAdmin}/orders/change-multi?_method=PATCH`, 'order')
        .card.mb-3
            .card-header Sắp xếp
                .card-body
                    .row
                        .col-8
                            +boxSort('order')
        .card.mb-3
            .card-header Danh sách đơn hàng
                .card-body
                    table(class="table table-hover table-sm")
                        thead
                            tr
                            th STT
                            th Mã đơn hàng
                            th Họ tên
                            th Số điện thoại
                            th Địa chỉ
                            th Tổng tiền
                            th Trạng thái
                            th Hành động
                        tbody
                            if orders && orders.length > 0
                                each item, index in orders
                                    tr
                                        td #{index + 1}
                                        td #{item.order_code}
                                        td #{item.userInfor.fullname}
                                        td #{item.userInfor.phone}
                                        td #{item.userInfor.address}
                                        td #{item.totalPrice.toLocaleString()}$
                                        td
                                            if item.status == 'pending'
                                                a(href="javascript:;" class="badge badge-success" button-change-status data-id=item._id  data-status=item.status) Chờ xử lý
                                            else if item.status == 'confirmed'
                                                a(href="javascript:;" class="badge badge-danger" button-change-status data-id=item._id  data-status=item.status) Đã xác nhận
                                            else if item.status == 'shipping'
                                                a(href="javascript:;" class="badge badge-warning" button-change-status data-id=item._id  data-status=item.status) Đang giao
                                            else if item.status == 'delivered'
                                                a(href="javascript:;" class="badge badge-primary" button-change-status data-id=item._id  data-status=item.status) Đã giao
                                            else 
                                                a(href="javascript:;" class="badge badge-secondary" button-change-status data-id=item._id  data-status=item.status) Đã hủy
                                        td
                                            a(href=`${prefixAdmin}/orders/details/${item._id}` class="btn btn-info btn-sm") Chi tiết
                                            if(permissions.includes("order_delete"))
                                                button(
                                                    type="button"
                                                    class="btn btn-danger btn-sm"
                                                    button-delete
                                                    data-id=item._id
                                                ) Xóa
                            else
                                tr
                                    td(colspan="7" class="text-center") Không có đơn hàng nào!  
        form(
            action=""
            method="POST"
            form-change-status
            data-path=`${prefixAdmin}/products/change-status`
        ) 
        form(
            action=""
            method="POST"
            form-delete
            data-path=`${prefixAdmin}/products/delete`
            )
        +pagination(objectPagination)
    else
        h1 Bạn không có quyền truy cập trang này!