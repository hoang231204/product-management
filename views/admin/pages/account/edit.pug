extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-error(5000)
    +alert-success(5000)

    .container.my-5
        .card.form-card
            h2(class="mb-4 text-center") Chỉnh sửa tài khoản
            form(
                action=`${prefixAdmin}/accounts/edit/${account.id}?_method=PATCH` 
                id="form-edit-account" 
                method="POST" 
                enctype="multipart/form-data" 
                form-upload
            )
                .row
                    .col-md-6
                        .form-group
                            label Họ tên
                            input(type="text" class="form-control" name="fullname" value=account.fullname required)
                    .col-md-6
                        .form-group
                            label Email
                            input(type="email" class="form-control" name="email" value=account.email required)
                
                .row
                    .col-md-6
                        .form-group
                            label Mật khẩu
                            input(type="password" class="form-control" name="password" placeholder="Nhập mật khẩu mới (để trống nếu không đổi)")
                    .col-md-6
                        .form-group
                            label Số điện thoại
                            input(type="text" class="form-control" name="phone" value=account.phone)

                .row
                    .col-md-6
                        .form-group
                            label Phân quyền
                            .action-box
                                select(name="role_id" class="form-control")
                                    each role in roles
                                        option(value=role._id selected=(account.role_id == role._id.toString())) #{role.title}
                    .col-md-6
                        .form-group
                            label Trạng thái
                            .d-flex.gap-3.mt-2
                                .form-check.form-check-inline
                                    input(type="radio" class="form-check-input" id="statusActive" name="status" value="active" checked=(account.status === "active"))
                                    label(for="statusActive" class="form-check-label") Hoạt động
                                .form-check.form-check-inline
                                    input(type="radio" class="form-check-input" id="statusInActive" name="status" value="inactive" checked=(account.status === "inactive"))
                                    label(for="statusInActive" class="form-check-label") Dừng hoạt động

                .row
                    .col-md-6
                        .form-group(upload-image)
                            label Avatar
                            input(type="file" class="form-control-file" name="avatar" accept="image/*" upload-image-input)
                            .box-image
                                img(src=account.avatar upload-image-preview class="image-preview")
                                button(type="button" class="btn-remove-image") ×

                .text-left.mt-4
                    button(type="submit" class="btn btn-primary px-5 mr-2") Cập nhật
                    a(href=`${prefixAdmin}/accounts` class="btn btn-secondary") Quay lại