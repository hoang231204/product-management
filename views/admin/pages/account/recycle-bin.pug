extends ../../layouts/default.pug
block main
    .container-fluid.mt-4
            h1 Thùng rác tài khoản
            
            .card.mb-3
                .card-header Danh sách tài khoản đã xóa
                .card-body
                    table(class="table table-hover table-sm")
                        thead
                            tr
                            th STT
                            th Avatar
                            th Họ tên
                            th Email
                            th Quyền
                            th Trạng thái
                            th Người xóa
                            th Thời gian xóa
                            th Hoạt động
                        tbody
                            if accounts.length > 0
                                each item, index in accounts
                                    tr
                                    td #{index + 1}
                                    td
                                        img(src=item.avatar, alt=item.fullName, width="40px", height="40px", class="rounded-circle")
                                    td #{item.fullName}
                                    td #{item.email}
                                    td #{item.roleTitle}
                                    td
                                        if item.status === 'active'
                                            span.badge.status-active Hoạt động
                                        else if item.status === 'inactive'
                                            span.badge.status-inactive Dừng hoạt động
                                    td #{item.deletedBy.account_id.fullName}
                                    td #{moment(item.deletedBy.deletedAt).format('DD/MM/YYYY HH:mm:ss')}
                                    
                                    td
                                        button(
                                            class="btn btn-success btn-sm" 
                                            button-restore 
                                            data-id=item._id
                                            ) Khôi phục
                                        button(
                                            class="btn btn-danger btn-sm ml-1" 
                                            button-hard-delete 
                                            data-id=item._id
                                            ) Xóa vĩnh viễn
                            else
                                tr
                                    td(colspan="9" class="text-center") Thùng rác trống.

    form(
      action=""
      method="POST"
      form-restore
      data-path=`${prefixAdmin}/accounts/recycle-bin/restore`
    )
    form(
      action=""
      method="POST"
      form-hard-delete
      data-path=`${prefixAdmin}/accounts/recycle-bin/hard-delete`
    )

    script(src="/admin/js/recycleBin.js")