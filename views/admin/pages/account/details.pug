extends ../../layouts/default.pug

block main
    .container.my-5
        h1.mb-4.font-weight-bold Chi tiết tài khoản
        
        .row
            //- Ảnh đại diện bên trái
            .col-4.text-center
                img(
                    src=(account.avatar ? account.avatar : "/admin/images/avatar-default.png")
                    class="img-fluid rounded-circle border"
                    style="width: 150px; height: 150px; object-fit: cover;"
                )
            
            //- Thông tin bên phải
            .col-8
                div(class="mb-2") <b>Họ tên:</b> #{account.fullname}
                div(class="mb-2") <b>Email:</b> #{account.email}
                div(class="mb-2") <b>Số điện thoại:</b> #{account.phone || "Chưa cập nhật"}
                div(class="mb-2") 
                    b Phân quyền: 
                    span #{account.role_id ? account.role_id.title : "Chưa phân quyền"}
                
                div(class="mb-3")
                    b Trạng thái: 
                    if account.status === "active"
                        span.badge.bg-success.text-white Hoạt động
                    else
                        span.badge.bg-danger.text-white Dừng hoạt động

                //- Phần Log: Người tạo
                if account.createdBy && account.createdBy.account_id
                    div(class="mt-4 pt-2 border-top")
                        div <b>Người tạo:</b> #{account.createdBy.account_id.fullname}
                        div.small.text-muted #{moment(account.createdBy.createdAt).format('DD/MM/YYYY HH:mm')}

                //- Phần Log: Lịch sử cập nhật (Giống phần Product)
                if account.updatedBy && account.updatedBy.length > 0
                    div(class="mt-3")
                        b Lịch sử cập nhật:
                        each item in account.updatedBy
                            if item.account_id
                                div(class="small border-bottom py-1 d-flex justify-content-between")
                                    span #{item.account_id.fullname} 
                                    span.text-muted #{moment(item.updatedAt).fromNow()}

        //- Cụm nút bấm
        div(class="mt-4")
            if(role.permissions.includes('account_edit'))
                a(href=`${prefixAdmin}/accounts/edit/${account.id}` class="btn btn-warning btn-sm mr-2") Chỉnh sửa
            a(href=`${prefixAdmin}/accounts` class="btn btn-secondary btn-sm") Quay lại