extends ../../layouts/default.pug

block main
    .container.my-5
        .row.justify-content-center
            .col-md-8.col-lg-6
                h1.mb-4.font-weight-bold Chi tiết tài khoản
                if (account.avatar)
                    div(class="mb-4 text-center")
                        img(
                            src=account.avatar
                            style="width: 150px; height: 150px; object-fit: cover; border-radius: 50%; border: 2px solid #ddd;"
                        )
                else
                    div(class="mb-4 text-center")
                        img(
                            src="/admin/images/avatar-default.png" 
                            style="width: 150px; height: 150px; object-fit: cover; border-radius: 50%; border: 2px solid #ddd;"
                        )

                .card.shadow-sm
                    .card-body
                        //- Họ tên
                        div(class="mb-3")
                            span(class="font-weight-bold") Họ tên: 
                            span #{account.fullname}

                        //- Email
                        div(class="mb-3")
                            span(class="font-weight-bold") Email: 
                            span #{account.email}

                        //- Số điện thoại
                        div(class="mb-3")
                            span(class="font-weight-bold") Số điện thoại: 
                            span #{account.phone ? account.phone : "Chưa cập nhật"}

                        //- Phân quyền (Role)
                        div(class="mb-3")
                            span(class="font-weight-bold") Phân quyền: 
                            span
                                if (account.role_id)
                                    | #{account.role_id.title}
                                else
                                    | Chưa phân quyền

                        //- Trạng thái
                        div(class="mb-3")
                            span(class="font-weight-bold") Trạng thái: 
                            if (account.status === "active")
                                span(class="badge bg-success ml-2") Hoạt động
                            else
                                span(class="badge bg-danger ml-2") Dừng hoạt động

                //- Nút hành động
                div(class="mt-4")
                    a(
                        href=`${prefixAdmin}/accounts/edit/${account.id}`
                        class="btn btn-warning"
                    ) Chỉnh sửa
                    a(
                        href=`${prefixAdmin}/accounts/delete/${account.id}`
                        class="btn btn-danger ml-2"
                        onclick="return confirm('Bạn có chắc chắn muốn xóa tài khoản này?');"
                    ) Xóa
                    a(
                        href=`${prefixAdmin}/accounts`
                        class="btn btn-secondary ml-2"
                    ) Quay lại