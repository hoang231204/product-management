extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-error(5000)
    +alert-success(5000)

    .container.my-5
        .detail-card
            h1.mb-4.text-primary #{account.fullname}
            .row
                //- Cột trái: Avatar và Thông tin chính
                .col-md-4
                    div(class="border-0 text-center")
                        img(
                            src=(account.avatar ? account.avatar : "/admin/images/avatar-default.png")
                            class="img-fluid img-detail mb-3"
                            style="max-height: 300px; object-fit: cover;"
                        )
                    .info-box.mt-3
                        p <b>Email:</b> #{account.email}
                        p <b>Số điện thoại:</b> #{account.phone || "Chưa cập nhật"}
                        p <b>Phân quyền:</b> #{account.role_id ? account.role_id.title : "Chưa phân quyền"}
                        p <b>Trạng thái:</b> #{account.status === 'active' ? "Hoạt động" : "Dừng"}

                //- Cột phải: Thông tin log và lịch sử
                .col-md-8
                    h5.mb-3 Thông tin hệ thống:
                    .description-box
                        if account.createdBy && account.createdBy.account_id
                            p <b>Người tạo:</b> #{account.createdBy.account_id.fullname}
                            p <b>Ngày tạo:</b> #{moment(account.createdBy.createdAt).format('DD/MM/YYYY HH:mm:ss')}
                        else
                            p.text-muted Chưa có thông tin người tạo.
                    
                    .mt-4.pt-3.border-top
                        h5.mb-3 Lịch sử cập nhật:
                        if account.updatedBy && account.updatedBy.length > 0
                            each item in account.updatedBy
                                if item.account_id
                                    .history-item
                                        div <b>#{item.account_id.fullname}</b> đã cập nhật
                                        div.small.text-muted #{moment(item.updatedAt).format('DD/MM/YYYY HH:mm:ss')}
                        else
                            p.text-muted Chưa có cập nhật nào.

            //- Cụm nút bấm
            .mt-4
                if role.permissions.includes("account_edit")
                    a(href=`${prefixAdmin}/accounts/edit/${account._id}` class="btn btn-warning mr-2") 
                        i.fa.fa-edit.mr-1 
                        | Chỉnh sửa
                a(href=`${prefixAdmin}/accounts` class="btn btn-secondary") 
                    i.fa.fa-arrow-left.mr-1 
                    | Quay lại danh sách