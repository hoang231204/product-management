extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-error(5000)
    +alert-success(5000)

    .container.my-5
        .detail-card
            h1.mb-4.text-primary #{user.fullname}
            .row
                .col-md-4
                    div(class="border-0 text-center")
                        img(
                            src=(user.avatar ? user.avatar : "/admin/images/avatar-default.png")
                            class="img-fluid img-detail mb-3" 
                            style="max-height: 300px; object-fit: cover; border-radius: 50%;"
                        )
                    .info-box.mt-3
                        p <b>Email:</b> #{user.email}
                        p <b>Số điện thoại:</b> #{user.phone || "Chưa cập nhật"}
                        p <b>Trạng thái:</b> 
                            span(class=user.status === 'active' ? "text-success font-weight-bold" : "text-danger font-weight-bold") #{user.status === 'active' ? "Hoạt động" : "Dừng hoạt động"}
                        p <b>Ngày tạo:</b> #{moment(user.createdAt).format('DD/MM/YYYY HH:mm:ss')}

                .col-md-8
                    h5.mb-3 Thông tin bổ sung:
                    .mt-4.pt-3.border-top
                        h5.mb-3 Lịch sử cập nhật:
                        if user.updatedBy && user.updatedBy.length > 0
                            each item in user.updatedBy
                                if item.account_id
                                    .history-item
                                        div <b>#{item.account_id.fullname}</b> đã cập nhật
                                        div.small.text-muted #{moment(item.updatedAt).format('DD/MM/YYYY HH:mm:ss')}
                        else
                            p.text-muted Chưa có cập nhật nào.

            .mt-4
                if role.permissions.includes("user_edit")
                    a(href=`${prefixAdmin}/users/edit/${user._id}` class="btn btn-warning mr-2") 
                        i.fa.fa-edit.mr-1 
                        | Sửa thông tin
                a(href=`${prefixAdmin}/users` class="btn btn-secondary") 
                    i.fa.fa-arrow-left.mr-1 
                    | Quay lại danh sách