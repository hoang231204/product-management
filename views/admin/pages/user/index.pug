extends ../../layouts/default.pug
include ../../mixins/show-alert.pug
block main
    if(role.permissions.includes('user_view'))
        +alert-success(5000)
        .container-fluid.my-4
            .row
                .col-12
                    h1.mb-4 Quản lý người dùng

                    .card.mb-3
                        .card-header 
                            .row.align-items-center
                                .col-md-6
                                    h5.mb-0 Danh sách người dùng
                                .col-md-6.text-right
                                    if(role.permissions.includes('user_create'))
                                        a(
                                            href=`${prefixAdmin}/users/create`
                                            class="btn btn-outline-success btn-sm dislay none"
                                            ) + Thêm mới

                        .card-body
                            table(class="table table-hover table-sm")
                                thead.thead-light
                                    tr
                                    th STT
                                    th Avatar
                                    th Họ tên
                                    th Email
                                    th Số điện thoại
                                    th Thời gian tạo
                                    th Người cập nhật
                                    th Trạng thái
                                    th Hành động
                                tbody
                                    if(users.length > 0)
                                        each item, index in users
                                            tr
                                                td.align-middle #{index + 1}
                                                td.align-middle
                                                    img(
                                                        src=(item.avatar ? item.avatar : "/admin/images/avatar-default.png")
                                                        alt=item.fullname
                                                        width="40px"
                                                        height="40px"
                                                        style="object-fit: cover; border-radius: 50%;"
                                                    )
                                                td.align-middle
                                                    if(item.fullname)
                                                        p #{item.fullname}
                                                    else
                                                        p.em Chưa cập nhật
                                                td.align-middle #{item.email}
                                                td.align-middle
                                                    if(item.phone)
                                                        p #{item.phone}
                                                    else
                                                        p.em Chưa cập nhật
                                                td.align-middle
                                                    p #{moment(item.createdAt).format('DD/MM/YYYY HH:mm:ss')}
                                                td.align-middle
                                                    if(item.updatedBy && item.updatedBy.length > 0)
                                                        p #{item.updatedBy[item.updatedBy.length - 1].account_id.fullname}
                                                        p #{moment(item.updatedBy[item.updatedBy.length - 1].updatedAt).format('DD/MM/YYYY HH:mm:ss')}
                                                    else
                                                        p.em Chưa được cập nhật
                                                td.align-middle
                                                    if(role.permissions.includes('user_edit'))
                                                        if (item.status === "active")
                                                            button(
                                                                class="badge badge-success border-0"
                                                                button-change-status
                                                                data-status=item.status
                                                                data-id=item.id
                                                                data-next-status="inactive"
                                                            ) Hoạt động
                                                        else
                                                            button(
                                                                class="badge badge-danger border-0"
                                                                button-change-status
                                                                data-status=item.status
                                                                data-id=item.id
                                                                data-next-status="active"
                                                            ) Dừng hoạt động
                                                td.align-middle
                                                    if(role.permissions.includes('user_edit'))
                                                        a(
                                                            href=`${prefixAdmin}/users/edit/${item._id}`
                                                            class="btn btn-warning btn-sm"
                                                            ) Sửa
                                                    if(role.permissions.includes('user_delete'))
                                                        button(
                                                            class="btn btn-danger btn-sm ml-1"
                                                            button-delete
                                                            data-id=item._id
                                                            ) Xóa
                                                    a(
                                                        href=`${prefixAdmin}/users/details/${item._id}`
                                                        class="btn btn-info btn-sm ml-1"
                                                        ) Chi tiết
                                    else
                                        tr
                                            td(colspan="8" class="text-center py-4") 
                                                em Không tìm thấy người dùng nào phù hợp.
        form(
            form-change-status
            method="POST"
            action=""
            data-path=`${prefixAdmin}/users/change-status`
        )
        form(
            method="POST"
            action=""
            data-path=`${prefixAdmin}/users/delete`
            form-delete
        )