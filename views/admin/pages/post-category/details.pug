extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-success(5000)
    
    .container.my-5
        .card.form-card
            h1(class="mb-4 text-center") CHI TIẾT DANH MỤC
            
            if category
                .row
                    //- Ảnh bên trái
                    .col-md-4
                        .mb-4.text-center
                            img(
                                src=(category.thumbnail ? category.thumbnail : "/admin/images/no-image.png")
                                class="img-fluid rounded shadow-sm border"
                                style="max-height: 300px; object-fit: cover;"
                            )
                    
                    //- Thông tin bên phải
                    .col-md-8
                        .info-section
                            .mb-3
                                b Tiêu đề: 
                                span.text-white #{category.title}
                            
                            .mb-3
                                b Danh mục cha: 
                                span.text-white #{parentName ? parentName : "Không có"}
                            
                            .mb-3
                                b Vị trí: 
                                span.badge.bg-info #{category.position}
                            
                            .mb-3
                                b Trạng thái: 
                                if category.status === "active"
                                    span.badge.bg-success Hoạt động
                                else
                                    span.badge.bg-danger Dừng hoạt động

                            .mb-4
                                b Mô tả:
                                div(class="mt-2 p-3 bg-dark border rounded") !{category.description || "<i>Không có mô tả</i>"}

                        //- Phần Log
                        .log-section.mt-4.pt-3.border-top
                            if category.createdBy && category.createdBy.account_id
                                .mb-2
                                    b Người tạo: 
                                    span.text-muted #{category.createdBy.account_id.fullname} - #{moment(category.createdBy.createdAt).format('DD/MM/YYYY HH:mm')}

                            if category.updatedBy && category.updatedBy.length > 0
                                .mt-3
                                    b Lịch sử cập nhật:
                                    ul.list-unstyled.mt-2
                                        each item in category.updatedBy
                                            if item.account_id
                                                li.small.border-bottom.py-2.d-flex.justify-content-between
                                                    span #{item.account_id.fullname} 
                                                    span.text-muted #{moment(item.updatedAt).fromNow()}

                //- Cụm nút bấm
                .text-right.mt-4
                    if(role.permissions.includes('post_categories_edit'))
                        a(href=`${prefixAdmin}/post-categories/${category._id}/edit` class="btn btn-warning px-4 mr-2") Chỉnh sửa
                    a(href=`${prefixAdmin}/post-categories` class="btn btn-secondary px-4") Quay lại

            else
                .alert.alert-warning Không tìm thấy danh mục này!
                a(href=`${prefixAdmin}/post-categories` class="btn btn-secondary") Quay lại danh sách