extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-success(5000)
    
    .container.my-5
        h1.mb-4.font-weight-bold CHI TIẾT DANH MỤC
        
        if category
            .row
                //- Ảnh bên trái
                .col-4
                    div(class="border rounded p-2 text-center bg-white")
                        img(
                            src=(category.thumbnail ? category.thumbnail : "/admin/images/no-image.png")
                            class="img-fluid"
                        )
                
                //- Thông tin bên phải
                .col-8
                    div(class="mb-2") <b>Tiêu đề:</b> #{category.title}
                    div(class="mb-2") <b>Danh mục cha:</b> #{parentName ? parentName : "Không có"}
                    div(class="mb-2") 
                        b Vị trí: 
                        span.badge.bg-info.text-white #{category.position}
                    
                    div(class="mb-2")
                        b Trạng thái: 
                        if category.status === "active"
                            span.badge.bg-success.text-white Hoạt động
                        else
                            span.badge.bg-danger.text-white Dừng hoạt động

                    div(class="mb-3")
                        b Mô tả:
                        div(class="mt-1 p-3 bg-light border rounded") !{category.description || "<i>Không có mô tả</i>"}

                    //- Phần Log: Người tạo
                    if category.createdBy && category.createdBy.account_id
                        div(class="mt-4 pt-2 border-top")
                            div <b>Người tạo:</b> #{category.createdBy.account_id.fullname}
                            div.small.text-muted #{moment(category.createdBy.createdAt).format('DD/MM/YYYY HH:mm')}

                    //- Phần Log: Lịch sử cập nhật (Giống Product)
                    if category.updatedBy && category.updatedBy.length > 0
                        div(class="mt-3")
                            b Lịch sử cập nhật:
                            each item in category.updatedBy
                                if item.account_id
                                    div(class="small border-bottom py-1 d-flex justify-content-between")
                                        span #{item.account_id.fullname} 
                                        span.text-muted #{moment(item.updatedAt).fromNow()}

            //- Cụm nút bấm
            div(class="mt-4")
                if(role.permissions.includes('categories_edit'))
                    a(href=`${prefixAdmin}/product-categories/${category._id}/edit` class="btn btn-warning btn-sm mr-2") Chỉnh sửa
                a(href=`${prefixAdmin}/product-categories` class="btn btn-secondary btn-sm") Quay lại

        else
            .alert.alert-warning Không tìm thấy danh mục này!
            a(href=`${prefixAdmin}/product-categories` class="btn btn-secondary btn-sm") Quay lại danh sách