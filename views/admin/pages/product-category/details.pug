extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-success(5000)

    .container.my-5
        .detail-card
            if category
                h1.mb-4.text-primary #{category.title}
                .row
                    //- Cột trái: Ảnh và Thông tin chính
                    .col-md-4
                        div(class="border-0 text-center")
                            img(
                                src=(category.thumbnail ? category.thumbnail : "/admin/images/no-image.png")
                                class="img-fluid img-detail mb-3"
                                style="max-height: 300px; object-fit: cover;"
                            )
                        .info-box.mt-3
                            p <b>Danh mục cha:</b> #{parentName ? parentName : "Không có"}
                            p <b>Vị trí:</b> #{category.position}
                            p <b>Trạng thái:</b> 
                                if category.status === "active"
                                    span.badge.badge-success Hoạt động
                                else
                                    span.badge.badge-danger Dừng hoạt động

                    //- Cột phải: Mô tả và Lịch sử
                    .col-md-8
                        h5.mb-3 Mô tả chi tiết:
                        .description-box
                            | !{category.description || "<i>Không có mô tả</i>"}
                        
                        .mt-4.pt-3.border-top
                            h5.mb-3 Thông tin hệ thống:
                            if category.createdBy && category.createdBy.account_id
                                p <b>Người tạo:</b> #{category.createdBy.account_id.fullname}
                                p.small.text-muted #{moment(category.createdBy.createdAt).format('DD/MM/YYYY HH:mm')}
                            
                            .mt-3
                                b Lịch sử cập nhật:
                                if category.updatedBy && category.updatedBy.length > 0
                                    each item in category.updatedBy
                                        if item.account_id
                                            .history-item
                                                div <b>#{item.account_id.fullname}</b> đã cập nhật
                                                div.small.text-muted #{moment(item.updatedAt).format('DD/MM/YYYY HH:mm:ss')}
                                else
                                    p.text-muted.small Chưa có cập nhật nào.

                //- Cụm nút bấm
                .mt-4
                    if(role.permissions.includes('product_category_edit'))
                        a(href=`${prefixAdmin}/product-categories/${category._id}/edit` class="btn btn-warning mr-2") 
                            i.fa.fa-edit.mr-1
                            | Chỉnh sửa
                    a(href=`${prefixAdmin}/product-categories` class="btn btn-secondary") 
                        i.fa.fa-arrow-left.mr-1
                        | Quay lại danh sách
            else
                .alert.alert-warning Không tìm thấy danh mục này!
                a(href=`${prefixAdmin}/product-categories` class="btn btn-secondary") 
                    i.fa.fa-arrow-left.mr-1
                    | Quay lại danh sách