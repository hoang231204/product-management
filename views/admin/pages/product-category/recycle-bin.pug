extends ../../layouts/default.pug

block main 
  .container-fluid.mt-4
    h1 Thùng rác danh mục
    
    .card.mb-3
      .card-header Danh sách danh mục đã xóa
      .card-body
        table(class="table table-hover table-sm")
          thead
            tr
              th STT
              th Hình ảnh
              th Tiêu đề
              th Người xóa
              th Thời gian xóa
              th Hoạt động
          tbody
            if categories.length > 0
                each item, index in categories
                    tr
                    td #{index + 1}
                    td
                        img(src=item.thumbnail, alt=item.title, width="100px", height="auto")
                    td #{item.title}
                    td #{item.deletedBy.account_id.fullName}
                    td #{moment(item.deletedBy.deletedAt).format('DD/MM/YYYY HH:mm')}
                    td
                        button(class="btn btn-success btn-sm" button-restore data-id=item.id) Khôi phục
                        button(class="btn btn-danger btn-sm ml-1" button-hard-delete data-id=item.id) Xóa vĩnh viễn
            else 
              tr 
                td(colspan="6" class="text-center") Thùng rác trống

    //- Form xử lý logic JS
    form(
      action=""
      method="POST"
      form-hard-delete
      data-path=`${prefixAdmin}/product-categories/recycle-bin/hard-delete`
    )
    form(
      action=""
      method="POST"
      form-restore 
      data-path=`${prefixAdmin}/product-categories/recycle-bin/restore`
    )
    
    script(src="/admin/js/recycleBin.js")