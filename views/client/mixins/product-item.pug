mixin product-item(item)
  .product-item
    .inner-image
      img(src=item.thumbnail, alt="Hình ảnh", srcset="")
      if(item.featured == "1")
        .inner-featured Nổi bật
      a(href=`/products/details/${item.slug}`) 
        h3.inner-title #{item.title}
      .inner-price-new #{item.priceNew}$
      .inner-price-old #{item.price}$
      .inner-discount -#{item.discountPercentage}%
mixin blog-item(item)
  .blog-item
    .inner-image
      img(src=item.thumbnail, alt="Hình ảnh", srcset="")
      a(href=`/blogs/details/${item.slug}`) 
        h3.inner-title #{item.title}
      .inner-description #{item.description}
      .inner-date #{item.createdAt}
      .inner-author Tác giả: 
        if(item.author)
          | #{item.author}
        else
          | Không rõ