extends ../../layouts/default.pug
include ../../mixins/show-alert.pug
block main
    +alert-success(3000)
    +alert-error(3000)
    h1.mb-4 Đơn hàng đã mua
    .card.mb-3
      .card-header Danh sách đơn hàng
      .card-body
        table(class="table table-hover table-sm")
          thead
            tr
              th STT
              th Họ tên
              th Số điện thoại
              th Địa chỉ
              th Tổng tiền
              th Trạng thái
              th Hành động
          tbody
            if orders && orders.length > 0
                each item, index in orders
                    tr
                        td #{index + 1}
                        td #{item.fullname}
                        td #{item.phone}
                        td #{item.address}
                        td #{item.totalPrice.toLocaleString()}$
                        td
                            if item.status == 'pending'
                                span.badge.badge-warning Đang chờ
                            else if item.status == 'confirmed'
                                span.badge.badge-info Đã xác nhận
                            else if item.status == 'shipped'
                                span.badge.badge-primary Đang giao
                            else if item.status == 'delivered'
                                span.badge.badge-success Đã giao
                            else
                                span.badge.badge-danger Đã hủy
                        td
                            a(href=`/orders/details/${item._id}` class="btn btn-info btn-sm") Chi tiết
                            button(type="button" class="btn btn-danger btn-sm ml-2" data-id=item._id button-cancel) Hủy đơn
            else
                tr
                    td(colspan="7" class="text-center") Không có đơn hàng nào!  
        form(
            action=""
            method="POST"
            form-cancel
            data-path=`/orders/cancel`
        )