extends ../../layouts/default.pug

block main
  .container.my-5
    div(class="alert alert-success mb-4" role="alert")
      | Chúc mừng bạn đã đặt hàng thành công! Chúng tôi sẽ xử lý đơn hàng trong thời gian sớm nhất.
    h4(class="mb-3 font-weight-bold") Thông tin cá nhân
    table(class="table table-bordered align-middle mb-5")
      tbody
        tr
          td(style="width: 30%;" class="fw-bold bg-light") Họ tên
          td #{order.userInfor.fullname}
        tr
          td(class="fw-bold bg-light") Số điện thoại
          td #{order.userInfor.phone}
        tr
          td(class="fw-bold bg-light") Địa chỉ
          td #{order.userInfor.address}
    h4(class="mb-3 font-weight-bold") Thông tin đơn hàng
    if order && order.products.length > 0
      table(class="table table-bordered text-center align-middle")
        thead(class="table-light")
          tr
            th STT
            th Ảnh
            th Tên
            th Giá
            th Số lượng
            th Tổng tiền
        tbody
          each item, index in order.products
            tr
              td #{index + 1}
              td
                img(src=item.product_id.thumbnail, alt=item.product_id.title, width="80px")
              td(class="text-start") #{item.product_id.title}
              td #{item.product_id.priceNew}$
              td #{item.quantity}
              td #{item.product_id.priceNew * item.quantity}$

      .text-end.mt-4
        h3 Tổng đơn hàng: 
          span(class="fw-bold") #{order.totalPrice}$