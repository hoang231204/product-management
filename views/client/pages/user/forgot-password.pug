extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main
    +alert-error(3000)
    +alert-success(3000)
  
    .container.my-5
        .row.justify-content-center
            .col-md-6
                h2(class="text-success mb-3") Lấy lại mật khẩu
                p(class="text-muted mb-4") Vui lòng nhập email tài khoản của bạn để hệ thống gửi mã OTP xác nhận.
                
                form(action="/user/password/forgot" method="POST")
                    div(class="mb-4")
                        label(for="email" class="form-label fw-bold") Địa chỉ Email
                        input(
                            type="email"
                            id="email"
                            name="email"
                            class="form-control"
                            placeholder="example@gmail.com"
                            required
                        )

                    button(type="submit" class="btn btn-success w-100 mb-3") Gửi email xác nhận
                div(class="text-center mt-3")
                    a(href="/user/login" class="text-secondary text-decoration-none small") Quay lại trang Đăng nhập