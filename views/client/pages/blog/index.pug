extends ../../layouts/default.pug 
include ../../mixins/box-head.pug
include ../../mixins/filter.pug
include ../../mixins/product-grid.pug
include ../../mixins/pagination.pug
block main
  +alert-success(3000)
  +alert-error(3000)
  .container
    .row
      .col-3
        +category-filter(categories)
  .container.my-3
    .row
      .col-10
        .box-head
          +boxhead(pageTitle)
    .row
      +blog-grid(blogs)
    +pagination(objectPagination)